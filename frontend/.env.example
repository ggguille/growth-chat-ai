# Build-time environment variables for the growth-chat widget
# Copy to .env.local for local development — never commit real values

# Required — injected by CI as GitHub Secrets
VITE_API_URL=https://api.example.com/chat
VITE_FALLBACK_URL=https://www.example.com/contact
VITE_API_KEY=
VITE_GDPR_NOTICE_TEXT=

# Optional — defaults used if unset
VITE_STREAM_TIMEOUT_MS=10000
VITE_DEFAULT_PROACTIVE_MESSAGE=Have a question about AI engineering?
