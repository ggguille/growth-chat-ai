# Environment (set to "production" to disable /docs and /redoc)
APP_ENV=development

# CORS — browser origin allowed to call the API (no trailing slash, no wildcards)
ALLOWED_ORIGIN=http://localhost:3000

# Widget authentication
ZGC_API_KEY=dev-key

# LLM — production (Anthropic Claude Haiku 4.5, ADR-001)
# Required in non-development environments
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# LLM — development (Ollama, ADR-001: Llama 3.1 8B)
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# LLM stream timeout
LLM_STREAM_TIMEOUT_MS=10000

# Database (Neon PostgreSQL)
CHECKPOINT_DB_URL=

# RAG — set RAG_RELEVANCE_THRESHOLD to 0.70 provisionally (tune in Phase 4)
# Required in non-development environments
RAG_RELEVANCE_THRESHOLD=0.70
RAG_TOP_K=5
# Use knowledge_chunks_dev for local dev, knowledge_chunks for prod
KNOWLEDGE_TABLE_NAME=knowledge_chunks_dev

# Embeddings — OpenAI (prod/staging); HuggingFace used locally when this is empty
OPENAI_API_KEY=

# Conversation orchestrator
STALL_TURN_THRESHOLD=6
CONTEXT_WINDOW_TURNS=10

# Business hours — required in non-development environments (IANA timezone identifier)
BUSINESS_HOURS_TIMEZONE=Europe/Madrid

# Slack
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

# Handoff fallback email
FALLBACK_EMAIL_ADDRESS=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
