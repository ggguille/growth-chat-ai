# Environment (set to "production" to disable /docs and /redoc)
APP_ENV=development

# CORS — browser origin allowed to call the API (no trailing slash, no wildcards)
ALLOWED_ORIGIN=http://localhost:3000

# Widget authentication
ZGC_API_KEY=dev-key

# LLM — production (Anthropic Claude Haiku 4.5, ADR-001)
# Required in non-development environments
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# LLM — development (Ollama, ADR-001: Llama 3.1 8B)
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# LLM stream timeout
LLM_STREAM_TIMEOUT_MS=10000

# Database (Neon PostgreSQL)
CHECKPOINT_DB_URL=

# RAG — set RAG_RELEVANCE_THRESHOLD callibrated from DEV model (Ollama) and adjust based on production model (Anthropic Claude Haiku 4.5) performance.
# Required in non-development environments
RAG_RELEVANCE_THRESHOLD=0.40
RAG_PROACTIVE_THRESHOLD=0.50   # default +0.10
RAG_TOP_K=5
# Use knowledge_chunks_dev for local dev, knowledge_chunks for prod
KNOWLEDGE_TABLE_NAME=knowledge_chunks_dev

# Embeddings — OpenAI (prod/staging); HuggingFace used locally when this is empty
OPENAI_API_KEY=

# Conversation orchestrator
STALL_TURN_THRESHOLD=6
CONTEXT_WINDOW_TURNS=10

# Business hours — required in non-development environments (IANA timezone identifier)
BUSINESS_HOURS_TIMEZONE=Europe/Madrid

# Slack
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

# Handoff fallback email
FALLBACK_EMAIL_ADDRESS=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Handoff retry — backoff delays (seconds) between attempts; default gives 4 attempts
HANDOFF_RETRY_BACKOFF_SECONDS=1,3,9

# Langfuse LLM observability (ADR-007) — all optional; omit to disable
# EU region endpoint satisfies GDPR data residency requirement
LANGFUSE_PUBLIC_KEY=pk-lf-
LANGFUSE_SECRET_KEY=sk-lf-
LANGFUSE_BASE_URL=https://eu.cloud.langfuse.com
# OTEL service name shown in Langfuse traces (defaults to growth-chat-api in code)
OTEL_SERVICE_NAME=growth-chat-api
