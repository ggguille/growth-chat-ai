# Copy to .env and set CHECKPOINT_DB_URL for your local Postgres instance.
# Production value is set as a secret in the GitHub Actions production environment — no .env file is used there.

# psycopg3 format (plain postgresql://).
CHECKPOINT_DB_URL=postgresql://growth:growth@localhost:5432/growth_chat
# CHUNK_SIZE=512
# CHUNK_OVERLAP=64
# Table to upsert into. Auto-detected from OPENAI_API_KEY if not set:
#   knowledge_chunks (OpenAI, 1536-dim) or knowledge_chunks_dev (HuggingFace, 384-dim).
# KNOWLEDGE_TABLE_NAME=knowledge_chunks
# Keep it empty to use local embedding model (HuggingFace). Set to a valid OpenAI API key to use OpenAI embeddings and the knowledge_chunks table.
OPENAI_API_KEY=
