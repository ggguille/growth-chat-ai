EVAL_API_URL=http://localhost:8000
ZGC_API_KEY=dev-key

# ── LLM-as-judge ─────────────────────────────────────────────────────────────
# Set JUDGE_PROVIDER to the provider you want to use as the evaluation judge.
# The judge is used by DeepEval GEval metrics (NoPricingDisclosure, NoFabrication,
# and inline per-test GEval criteria).

# Dev — local Ollama (no API key required; Ollama must be running)
JUDGE_PROVIDER=ollama
JUDGE_MODEL=qwen2.5:7b # llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# CI / production — Anthropic Claude Haiku
# (comment out the Ollama block above before enabling this)
# JUDGE_PROVIDER=anthropic
# JUDGE_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=

# ── Langfuse integration — eval scores and RAGAS experiments ─────────────────
# Required to ship evaluation results to Langfuse for inspection.
# DeepEval auto-detects these and ships metric scores as traces.
# The RAGAS runner logs experiments to Datasets → rag_eval.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://eu.cloud.langfuse.com
OTEL_SERVICE_NAME=growth-chat-eval

# ── promptfoo red team — LLM judge (llm-rubric assertions) ───────────────────
# OLLAMA_BASE_URL is shared with the DeepEval block above.

# Dev — local Ollama (default; no API key required)
PROMPTFOO_GRADING_PROVIDER=ollama:chat:qwen2.5:7b

# CI / production — Claude Haiku 4.5 via Anthropic API
# (comment out the Ollama line above before enabling this)
# PROMPTFOO_GRADING_PROVIDER=anthropic:messages:claude-haiku-4-5-20251001

# ── RAGAS RAG evaluation ──────────────────────────────────────────────────────
# Requires: KB ingested and RAG pipeline active (Phase 2+).
# ANTHROPIC_API_KEY (from the CI block above) is reused as the RAGAS judge LLM key.
#
# psycopg3 connection string for pgvector.
# Defaults to CHECKPOINT_DB_URL if unset (shared with the backend).
RAGAS_DB_URL=postgresql+psycopg://user:pass@localhost:5432/dbname
#
# Embedding mode must match the table used during ingestion:
#   dev  → knowledge_chunks_dev  (sentence-transformers all-MiniLM-L6-v2, 384-dim)
#   prod → knowledge_chunks      (OpenAI text-embedding-3-small, 1536-dim)
RAGAS_EMBEDDING_MODE=dev
#
# Number of chunks to retrieve per question (must match RAG_TOP_K in the backend).
RAGAS_TOP_K=7
#
# Max concurrent LLM calls sent to the RAGAS judge (default 2, within 50 req/min limit).
# Raise carefully if you have a higher Anthropic API tier.
RAGAS_MAX_WORKERS=2
#
# Required only when RAGAS_EMBEDDING_MODE=prod:
# OPENAI_API_KEY=
