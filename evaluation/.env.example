EVAL_API_URL=http://localhost:8000
ZGC_API_KEY=dev-key

# ── LLM-as-judge: uncomment ONE block ────────────────────────────────────────

# Dev — local Ollama (no API key required; requires Ollama running locally)
LOCAL_MODEL_API_KEY=ollama
LOCAL_MODEL_NAME=llama4:8b
OLLAMA_BASE_URL=http://localhost:11434

# CI / production — Claude Sonnet 4.6 via Anthropic API
# (comment out the Ollama block above before enabling this)
# USE_ANTHROPIC_MODEL=true
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL_NAME=claude-sonnet-4-6   # optional; default is already claude-sonnet-4-6

# ── Langfuse integration — eval scores logged as traces (optional) ────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://eu.cloud.langfuse.com
